




---
import MainLayout from '../layouts/main.astro';
import { Button } from '../components/ui/button';
import { Label } from '../components/ui/label';
import { Input } from '../components/ui/input';
import { Textarea } from '../components/ui/textarea';
import { baseUrl } from '../lib/base-url';
---

<MainLayout pageClass="submit">
  <div class="min-h-screen bg-background">
    <div class="container mx-auto px-4 py-12">
      <div class="max-w-2xl mx-auto">
        <header class="mb-12 text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-4 font-heading bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent">
            Submit Your Work
          </h1>
          <p class="text-lg text-muted-foreground">
            Share your creative work with our community. Upload images or videos to showcase your portfolio.
          </p>
        </header>

        <div id="form-container">
          <form id="submit-form" class="space-y-6 bg-card border border-border rounded-lg p-8 shadow-sm" onsubmit="return false;">
            <div>
              <label for="name" class="block text-sm font-medium mb-2">
                Your Name <span class="text-destructive">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2 rounded-md border border-input bg-background focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="John Doe"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium mb-2">
                Email <span class="text-destructive">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 rounded-md border border-input bg-background focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="john@example.com"
              />
              <p class="text-xs text-muted-foreground mt-1">We'll notify you when your work is published</p>
            </div>

            <div>
              <label for="title" class="block text-sm font-medium mb-2">
                Project Title <span class="text-destructive">*</span>
              </label>
              <input
                type="text"
                id="title"
                name="title"
                required
                class="w-full px-4 py-2 rounded-md border border-input bg-background focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="My Amazing Project"
              />
            </div>

            <div>
              <label for="description" class="block text-sm font-medium mb-2">
                Description <span class="text-destructive">*</span>
              </label>
              <textarea
                id="description"
                name="description"
                required
                rows="4"
                class="w-full px-4 py-2 rounded-md border border-input bg-background focus:outline-none focus:ring-2 focus:ring-ring resize-none"
                placeholder="Tell us about your project..."
              ></textarea>
            </div>

            <!-- Media Type Selection -->
            <div>
              <label class="block text-sm font-medium mb-3">
                Upload Type <span class="text-destructive">*</span>
              </label>
              <div class="flex gap-4">
                <label class="flex items-center cursor-pointer">
                  <input
                    type="radio"
                    name="media-type"
                    value="image"
                    checked
                    class="w-4 h-4 text-primary focus:ring-2 focus:ring-ring"
                  />
                  <span class="ml-2">Image</span>
                </label>
                <label class="flex items-center cursor-pointer">
                  <input
                    type="radio"
                    name="media-type"
                    value="video"
                    class="w-4 h-4 text-primary focus:ring-2 focus:ring-ring"
                  />
                  <span class="ml-2">Video</span>
                </label>
              </div>
            </div>

            <!-- Image Upload Section -->
            <div id="image-upload-section">
              <label for="image" class="block text-sm font-medium mb-2">
                Upload Image <span class="text-destructive">*</span>
              </label>
              <div class="space-y-3">
                <input
                  type="file"
                  id="image"
                  name="image"
                  accept="image/*"
                  class="w-full px-4 py-2 rounded-md border border-input bg-background focus:outline-none focus:ring-2 focus:ring-ring file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary file:text-primary-foreground hover:file:bg-primary/90 cursor-pointer"
                />
                <div id="image-preview" class="hidden">
                  <div class="relative w-full max-w-md mx-auto">
                    <img id="preview-img" src="" alt="Preview" class="w-full h-auto rounded-lg border border-border" />
                    <button
                      type="button"
                      id="remove-image"
                      class="absolute top-2 right-2 bg-destructive text-white rounded-full p-2 hover:bg-destructive/90 transition-colors"
                      title="Remove image"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    </button>
                  </div>
                  <p class="text-xs text-muted-foreground text-center mt-2" id="file-size"></p>
                </div>
              </div>
              <p class="text-xs text-muted-foreground mt-1">
                Upload JPG, PNG, or WebP (max 10MB)
              </p>
            </div>

            <!-- Video Upload Section -->
            <div id="video-upload-section" class="hidden">
              <label class="block text-sm font-medium mb-2">
                Upload Video <span class="text-destructive">*</span>
              </label>
              <div id="video-upload-container"></div>
              
              <div class="mt-3 p-4 bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800 rounded-lg">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                  <div class="text-sm space-y-2">
                    <p class="font-semibold text-amber-900 dark:text-amber-100">⚠️ Important: Video Compatibility</p>
                    <p class="text-amber-800 dark:text-amber-200">
                      <strong>Videos must be encoded with H.264 codec to play in browsers.</strong>
                    </p>
                    <div class="text-xs text-amber-700 dark:text-amber-300 space-y-1">
                      <p><strong>✅ Best Format:</strong> MP4 with H.264 video codec</p>
                      <p><strong>❌ Won't Work:</strong> iPhone videos (HEVC/H.265), some screen recordings, certain MOV files</p>
                      <p><strong>🔧 Need to convert?</strong> Use <a href="https://handbrake.fr/" target="_blank" rel="noopener noreferrer" class="underline font-medium hover:text-amber-600">HandBrake</a> (free) with the "Web" preset</p>
                      <p><strong>📱 iPhone users:</strong> Your videos may not play unless converted to H.264 first</p>
                    </div>
                  </div>
                </div>
              </div>
              
              <p class="text-xs text-muted-foreground mt-2">
                Maximum file size: 500MB • Recommended: MP4 (H.264) under 200MB
              </p>
            </div>

            <div>
              <label for="website" class="block text-sm font-medium mb-2">
                Portfolio/Website Link (Optional)
              </label>
              <input
                type="url"
                id="website"
                name="website"
                class="w-full px-4 py-2 rounded-md border border-input bg-background focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="https://yourportfolio.com"
              />
            </div>

            <div class="pt-4">
              <button
                type="button"
                id="submit-btn"
                class="w-full bg-primary text-primary-foreground hover:bg-primary/90 font-medium py-3 px-6 rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Submit Your Work
              </button>
            </div>
          </form>

          <div id="success-message" class="hidden bg-primary/10 border border-primary rounded-lg p-8 text-center">
            <div class="text-5xl mb-4">✨</div>
            <h2 class="text-2xl font-bold mb-2 font-heading text-primary">Submission Received!</h2>
            <p class="text-muted-foreground mb-6">
              Thank you for sharing your work! We'll review it and add it to the portfolio grid soon.
            </p>
            <button
              id="submit-another"
              class="bg-primary text-primary-foreground hover:bg-primary/90 font-medium py-2 px-6 rounded-md transition-colors"
            >
              Submit Another
            </button>
          </div>

          <div id="error-message" class="hidden bg-destructive/10 border border-destructive rounded-lg p-6 text-center">
            <h3 class="text-lg font-semibold text-destructive mb-2">Submission Failed</h3>
            <p class="text-sm text-muted-foreground mb-4" id="error-text"></p>
            <button
              id="try-again"
              class="bg-primary text-primary-foreground hover:bg-primary/90 font-medium py-2 px-4 rounded-md transition-colors text-sm"
            >
              Try Again
            </button>
          </div>
        </div>

        <div class="mt-8 text-center">
          <a href="/portfolio" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            ← View Portfolio Grid
          </a>
        </div>
      </div>
    </div>
  </div>

  <div id="react-video-root"></div>
</MainLayout>

<script>
import './submit-form.ts';
</script>

<style>
.container {
  max-width: 1280px;
}
</style>


























