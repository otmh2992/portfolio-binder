---
import MainLayout from '../layouts/main.astro';
import NavBar from '../components/NavBar';
import VideoUpload from '../components/VideoUpload';
---

<MainLayout pageClass="submit-work">
  <div class="min-h-screen bg-background grey-texture">
    <!-- Sticky Navigation Banner -->
    <NavBar client:load />

    <!-- Main Content -->
    <div class="container mx-auto px-4 py-12">
      <main>
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <h1 class="text-4xl font-bold font-heading mb-4">Submit Your Work</h1>
            <p class="text-lg text-muted-foreground">
              Share your creative projects with the community
            </p>
          </div>

          <VideoUpload client:only="react" />
        </div>
      </main>
    </div>
  </div>
</MainLayout>

<style>
  .container {
    max-width: 1280px;
  }
</style>
