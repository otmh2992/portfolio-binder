---
import MainLayout from '../layouts/main.astro';

const requestedPath = Astro.url.pathname;
const fullUrl = Astro.url.href;
---

<MainLayout pageClass="error-page">
  <div class="min-h-screen flex items-center justify-center bg-background px-4">
    <div class="max-w-2xl w-full text-center">

      <h1 class="text-6xl font-bold mb-4">404</h1>
      <h2 class="text-2xl mb-4">Page Not Found</h2>

      <div class="bg-muted p-6 rounded-lg mb-6 text-left">
        <p><strong>Requested:</strong> {requestedPath}</p>
        <p><strong>Full URL:</strong> {fullUrl}</p>
      </div>

      <p class="mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <div class="flex gap-4 justify-center">
        <a href="/" class="px-4 py-2 border rounded">
          Go Home
        </a>

        <a href="/login" class="px-4 py-2 border rounded">
          Login
        </a>
      </div>

    </div>
  </div>
</MainLayout>