
---
import '../../generated/fonts.css';
import '../site-components/global.css';
import '../styles/global.css';

const { pageClass = '' } = Astro.props;
---

<html lang="en" class={pageClass}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Portfolio Binder</title>
	</head>
	<!-- Dark mode class injection point - will be replaced with `dark` class based on your site palette -->
	<body class="__DARK_MODE_CLASS__">
    <slot />
  </body>
  <script>
  // Remove Webflow badge
  function removeWebflowBadge() {
    const badges = document.querySelectorAll('a[href*="webflow.com"]');
    badges.forEach(badge => {
      if (badge.href.includes('badge') || badge.href.includes('utm_campaign=brandjs')) {
        badge.remove();
      }
    });
  }
  
  // Run on load and after a delay (in case badge loads late)
  removeWebflowBadge();
  setTimeout(removeWebflowBadge, 1000);
  setTimeout(removeWebflowBadge, 2000);
  
  // Watch for DOM changes
  const observer = new MutationObserver(removeWebflowBadge);
  observer.observe(document.body, { childList: true, subtree: true });
</script>
</html>

<style is:global>
  /* Page-specific overrides */
  html.splash main { 
    display: flex !important; 
  }
  
  html.splash ol,
  html.splash ul { 
    padding-left: 0 !important; 
    margin: 0 !important; 
  }
</style>
