---
// filepath: src/pages/ai-chat.astro
import Layout from '../layouts/main.astro';
import { checkOllamaStatus } from '../lib/ollama';

const status = await checkOllamaStatus();
---

<Layout title="AI Chat Demo">
  <main class="container">
    <h1>🤖 AI Chat Demo</h1>
    
    <div class="status">
      <p>Status: {status.available ? '🟢 Online' : '🔴 Offline'}</p>
      {status.model && <p>Model: {status.model}</p>}
      {status.error && <p class="error">Error: {status.error}</p>}
    </div>

    <div id="chat-container">
      <div id="messages"></div>
      
      <form id="chat-form">
        <input 
          type="text" 
          id="user-input" 
          placeholder="Type a message..." 
          disabled={!status.available}
        />
        <button type="submit" disabled={!status.available}>
          Send
        </button>
      </form>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    background: #1a1a2e;
    min-height: 100vh;
    color: #eee;
  }
  
  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #00d4ff;
  }
  
  .status {
    padding: 1rem;
    background: #16213e;
    border-radius: 8px;
    margin-bottom: 1rem;
    border: 1px solid #0f3460;
  }
  
  .error {
    color: #ff6b6b;
  }
  
  #chat-container {
    border: 1px solid #0f3460;
    border-radius: 8px;
    overflow: hidden;
    background: #16213e;
  }
  
  #messages {
    height: 400px;
    overflow-y: auto;
    padding: 1rem;
    background: #0f0f23;
  }
  
  .message {
    margin-bottom: 1rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
  }
  
  .message.user {
    background: #0f3460;
    margin-left: 20%;
  }
  
  .message.assistant {
    background: #1a1a2e;
    margin-right: 20%;
    border: 1px solid #0f3460;
  }
  
  #chat-form {
    display: flex;
    gap: 0.5rem;
    padding: 1rem;
    border-top: 1px solid #0f3460;
  }
  
  #user-input {
    flex: 1;
    padding: 0.5rem;
    border: 1px solid #0f3460;
    border-radius: 4px;
    background: #1a1a2e;
    color: #eee;
  }
  
  #user-input:focus {
    outline: none;
    border-color: #00d4ff;
  }
  
  button {
    padding: 0.5rem 1rem;
    background: #00d4ff;
    color: #1a1a2e;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
  }
  
  button:disabled {
    background: #555;
    cursor: not-allowed;
  }
</style>

<script>
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('user-input') as HTMLInputElement;
  const messages = document.getElementById('messages');
  
  const messagesHistory: { role: string; content: string }[] = [];
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const userMessage = input.value.trim();
    if (!userMessage) return;
    
    // Add user message to UI
    addMessage('user', userMessage);
    messagesHistory.push({ role: 'user', content: userMessage });
    input.value = '';
    
    // Show loading
    const loadingId = addMessage('assistant', 'Thinking...');
    
    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: messagesHistory }),
      });
      
      const data = await response.json();
      
      // Remove loading message
      const loadingEl = document.getElementById(loadingId);
      if (loadingEl) loadingEl.remove();
      
      // Add assistant response
      addMessage('assistant', data.response);
      messagesHistory.push({ role: 'assistant', content: data.response });
    } catch (error) {
      const loadingEl = document.getElementById(loadingId);
      if (loadingEl) loadingEl.remove();
      addMessage('assistant', 'Error: ' + (error as Error).message);
    }
  });
  
  function addMessage(role: string, content: string): string {
    const id = 'msg-' + Date.now();
    const div = document.createElement('div');
    div.id = id;
    div.className = `message ${role}`;
    div.textContent = content;
    messages?.appendChild(div);
    messages?.scrollTo(0, messages.scrollHeight);
    return id;
  }
</script>